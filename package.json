    "prompttrace": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "server/",
    "public/favicon.svg",
    "index.html",
    "tsconfig.json",
    "tsconfig.server.json",
    "vite.config.ts",
    "postcss.config.mjs",
    "vite-env.d.ts",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmetseha/prompt-trace.git"
  },
  "homepage": "https://github.com/ahmetseha/prompt-trace",
  "bugs": {
    "url": "https://github.com/ahmetseha/prompt-trace/issues"
  },
  "author": "ahmetseha",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "db:seed": "npx tsx scripts/seed.ts"
